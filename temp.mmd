erDiagram
    auth_users ||--o| profiles : "has"
    profiles ||--o{ experiences : "has"
    profiles ||--o{ educations : "has"
    profiles ||--o{ skills : "has"
    profiles ||--o| user_cvs : "has"
    profiles ||--o| user_resume_data : "has"
    
    auth_users {
        uuid id PK
        string email
        jsonb user_metadata
    }
    
    profiles {
        uuid id PK
        string full_name
        string country
        string city
        timestamp updated_at
    }
    
    experiences {
        uuid id PK
        uuid user_id FK
        string company
        string role
        date start_date
        date end_date
    }
    
    educations {
        string id PK
        uuid user_id FK
        string school
        string degree
        string field_of_study
        string start_month
        string start_year
        string end_month
        string end_year
        string activities
        string description
        timestamp created_at
    }
    
    skills {
        uuid id PK
        uuid user_id FK
        string name
        string level
    }
    
    user_cvs {
        uuid id PK
        uuid user_id FK
        string file_name
        string file_path
        int file_size
        string file_type
    }
    
    jobs {
        bigint id PK
        string url UK
        string tieu_de
        string cong_ty
        string dia_diem
        string muc_luong
        string nganh_nghe_chuan_hoa
        jsonb ky_nang
        string job_hash_id
        jsonb thong_tin_tuyen_dung
        timestamp created_at
    }