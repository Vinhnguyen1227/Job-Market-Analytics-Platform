NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Docker Local Services Connection Strings
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://admin:secret_password_123@localhost:27017
ELASTICSEARCH_NODE=http://localhost:9200

# Scraper Configuration
SCRAPER_MAX_PAGES=5          # Number of listing pages to scrape per run
SCRAPER_DELAY_MS=7000        # Delay between page requests (milliseconds)
SCRAPER_SITE_URL=https://vn.joboko.com  # Base URL of the scraping target
